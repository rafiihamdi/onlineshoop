<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Shop - Solusi Belanja Praktis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap');
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }

        .cart-animate {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        /* Sembunyikan Scrollbar */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">

    <!-- Navigasi -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-2">
                    <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg">
                        <i data-lucide="shopping-bag"></i>
                    </div>
                    <span class="text-xl font-bold tracking-tight">LUXEShop</span>
                </div>

                <div class="hidden md:flex items-center space-x-8 text-sm font-medium">
                    <a href="#" class="hover:text-indigo-600 transition">Beranda</a>
                    <a href="#katalog" class="hover:text-indigo-600 transition">Katalog</a>
                    <a href="#tentang" class="hover:text-indigo-600 transition">Tentang Kami</a>
                </div>

                <div class="flex items-center gap-4">
                    <button onclick="toggleCart()" class="relative p-2 text-gray-600 hover:text-indigo-600 transition">
                        <i data-lucide="shopping-cart"></i>
                        <span id="cart-count" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full hidden">0</span>
                    </button>
                    <button class="md:hidden p-2 text-gray-600">
                        <i data-lucide="menu"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Bagian Hero -->
    <header class="relative overflow-hidden bg-white pt-16 pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-center">
                <div class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800 mb-4">
                        Koleksi Baru 2024
                    </span>
                    <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-6xl">
                        Tingkatkan Gaya Anda dengan <span class="text-indigo-600">Kualitas Premium</span>
                    </h1>
                    <p class="mt-6 text-lg text-gray-500">
                        Temukan kurasi produk eksklusif mulai dari fashion hingga gadget dengan harga terbaik dan pengiriman instan.
                    </p>
                    <div class="mt-10 flex flex-col sm:flex-row gap-4 sm:justify-center lg:justify-start">
                        <a href="#katalog" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full text-white bg-indigo-600 hover:bg-indigo-700 shadow-xl transition-all hover:scale-105">
                            Belanja Sekarang
                        </a>
                        <a href="#" class="inline-flex items-center justify-center px-8 py-3 border border-gray-200 text-base font-medium rounded-full text-gray-700 bg-white hover:bg-gray-50 transition-all">
                            Lihat Promo
                        </a>
                    </div>
                </div>
                <div class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center">
                    <div class="relative mx-auto w-full rounded-3xl shadow-2xl overflow-hidden aspect-square bg-gray-100">
                        <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&q=80&w=800" alt="Hero Image">
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Kategori -->
    <section class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 overflow-x-auto no-scrollbar flex gap-4">
            <button onclick="filterCategory('all')" class="category-btn active px-6 py-2 rounded-full border border-indigo-600 bg-indigo-600 text-white whitespace-nowrap">Semua</button>
            <button onclick="filterCategory('Elektronik')" class="category-btn px-6 py-2 rounded-full border border-gray-200 hover:border-indigo-600 transition whitespace-nowrap text-gray-600">Elektronik</button>
            <button onclick="filterCategory('Fashion')" class="category-btn px-6 py-2 rounded-full border border-gray-200 hover:border-indigo-600 transition whitespace-nowrap text-gray-600">Fashion</button>
            <button onclick="filterCategory('Aksesoris')" class="category-btn px-6 py-2 rounded-full border border-gray-200 hover:border-indigo-600 transition whitespace-nowrap text-gray-600">Aksesoris</button>
        </div>
    </section>

    <!-- Grid Produk -->
    <main id="katalog" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="flex justify-between items-end mb-8">
            <div>
                <h2 class="text-3xl font-bold text-gray-900">Produk Unggulan</h2>
                <p class="text-gray-500 mt-2">Kualitas terbaik yang dipilih khusus untuk Anda.</p>
            </div>
        </div>

        <div id="product-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Produk akan dimasukkan ke sini oleh JS -->
        </div>
    </main>

    <!-- Footer -->
    <footer id="tentang" class="bg-gray-900 text-white py-16">
        <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-12">
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center text-white">
                        <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                    </div>
                    <span class="text-xl font-bold">LUXEShop</span>
                </div>
                <p class="text-gray-400 leading-relaxed">
                    Toko online terpercaya yang menyediakan barang-barang berkualitas tinggi dengan pelayanan prima sejak 2020.
                </p>
            </div>
            <div>
                <h4 class="text-lg font-semibold mb-6">Metode Pembayaran</h4>
                <div class="flex flex-wrap gap-4 opacity-60">
                    <span class="bg-gray-800 px-3 py-1 rounded border border-gray-700">Bank Transfer</span>
                    <span class="bg-gray-800 px-3 py-1 rounded border border-gray-700">E-Wallet (OVO/Gopay)</span>
                    <span class="bg-gray-800 px-3 py-1 rounded border border-gray-700">QRIS</span>
                </div>
            </div>
            <div>
                <h4 class="text-lg font-semibold mb-6">Kontak Kami</h4>
                <ul class="space-y-4 text-gray-400">
                    <li class="flex items-center gap-2">
                        <i data-lucide="mail" class="w-4 h-4"></i> hello@luxeshop.com
                    </li>
                    <li class="flex items-center gap-2">
                        <i data-lucide="phone" class="w-4 h-4"></i> +62 812 3456 7890
                    </li>
                </ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 mt-16 pt-8 border-t border-gray-800 text-center text-sm text-gray-500">
            &copy; 2024 LUXEShop. Didesain untuk Blogspot.
        </div>
    </footer>

    <!-- Sidebar Keranjang Belanja -->
    <div id="cart-sidebar" class="fixed inset-y-0 right-0 w-full max-w-md bg-white shadow-2xl z-[60] translate-x-full transition-transform duration-300 flex flex-col">
        <div class="p-6 border-b flex justify-between items-center">
            <h3 class="text-xl font-bold">Keranjang Saya</h3>
            <button onclick="toggleCart()" class="p-2 hover:bg-gray-100 rounded-full">
                <i data-lucide="x"></i>
            </button>
        </div>
        
        <div id="cart-items" class="flex-1 overflow-y-auto p-6 space-y-4">
            <!-- Barang keranjang akan dimasukkan ke sini -->
            <div id="empty-cart-msg" class="text-center py-12 text-gray-400">
                <i data-lucide="shopping-cart" class="w-12 h-12 mx-auto mb-4 opacity-20"></i>
                <p>Keranjang masih kosong</p>
            </div>
        </div>

        <div class="p-6 border-t bg-gray-50">
            <div class="flex justify-between text-lg font-bold mb-6">
                <span>Total</span>
                <span id="cart-total">Rp 0</span>
            </div>
            <button onclick="checkout()" class="w-full bg-indigo-600 text-white py-4 rounded-xl font-bold hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                Lanjutkan ke WhatsApp
            </button>
        </div>
    </div>

    <!-- Overlay -->
    <div id="cart-overlay" onclick="toggleCart()" class="fixed inset-0 bg-black/30 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity"></div>

    <script>
        // Data Produk
        const products = [
            { id: 1, name: "Smart Watch Ultra v2", category: "Elektronik", price: 2499000, img: "https://images.unsplash.com/photo-1546868871-70c122469d8b?auto=format&fit=crop&q=80&w=400" },
            { id: 2, name: "Classic White Sneakers", category: "Fashion", price: 850000, img: "https://images.unsplash.com/photo-1560769629-975ec94e6a86?auto=format&fit=crop&q=80&w=400" },
            { id: 3, name: "Minimalist Leather Backpack", category: "Aksesoris", price: 1200000, img: "https://images.unsplash.com/photo-1548036328-c9fa89d128fa?auto=format&fit=crop&q=80&w=400" },
            { id: 4, name: "Wireless Noise Cancelling", category: "Elektronik", price: 3200000, img: "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?auto=format&fit=crop&q=80&w=400" },
            { id: 5, name: "Premium Denim Jacket", category: "Fashion", price: 725000, img: "https://images.unsplash.com/photo-1576871333019-220ef346dd9b?auto=format&fit=crop&q=80&w=400" },
            { id: 6, name: "Sunglasses Retro Black", category: "Aksesoris", price: 450000, img: "https://images.unsplash.com/photo-1511499767350-a1590fdb2863?auto=format&fit=crop&q=80&w=400" },
            { id: 7, name: "Mechanical Gaming Keyboard", category: "Elektronik", price: 1100000, img: "https://images.unsplash.com/photo-1511467687858-23d96c32e4ae?auto=format&fit=crop&q=80&w=400" },
            { id: 8, name: "Organic Cotton T-Shirt", category: "Fashion", price: 299000, img: "https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&q=80&w=400" },
        ];

        let cart = [];

        // Fungsi aman untuk inisialisasi ikon
        function refreshIcons() {
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }

        // Render Produk
        function renderProducts(filter = 'all') {
            const productList = document.getElementById('product-list');
            if (!productList) return;
            productList.innerHTML = '';

            const filtered = filter === 'all' ? products : products.filter(p => p.category === filter);

            filtered.forEach(product => {
                const div = document.createElement('div');
                div.className = 'product-card bg-white rounded-2xl p-4 transition-all duration-300 border border-gray-100 group';
                div.innerHTML = `
                    <div class="relative overflow-hidden rounded-xl aspect-square mb-4">
                        <img src="${product.img}" alt="${product.name}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        <button onclick="addToCart(${product.id})" class="absolute bottom-4 right-4 bg-white/90 backdrop-blur p-3 rounded-full shadow-lg hover:bg-indigo-600 hover:text-white transition-colors duration-300">
                            <i data-lucide="plus" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <div class="space-y-1">
                        <span class="text-xs font-semibold text-indigo-600 uppercase tracking-wider">${product.category}</span>
                        <h3 class="font-bold text-gray-900 line-clamp-1">${product.name}</h3>
                        <p class="text-lg font-bold text-gray-900">${formatIDR(product.price)}</p>
                    </div>
                `;
                productList.appendChild(div);
            });
            refreshIcons();
        }

        // Filter Kategori
        function filterCategory(cat) {
            document.querySelectorAll('.category-btn').forEach(btn => {
                btn.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600');
                btn.classList.add('text-gray-600', 'border-gray-200');
            });
            if (event && event.target) {
                event.target.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600');
            }
            renderProducts(cat);
        }

        // Logika Keranjang
        function toggleCart() {
            const sidebar = document.getElementById('cart-sidebar');
            const overlay = document.getElementById('cart-overlay');
            const isOpen = sidebar.classList.contains('translate-x-0');

            if (isOpen) {
                sidebar.classList.add('translate-x-full');
                sidebar.classList.remove('translate-x-0');
                overlay.classList.add('hidden');
                overlay.classList.remove('opacity-100');
            } else {
                sidebar.classList.remove('translate-x-full');
                sidebar.classList.add('translate-x-0');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);
            }
        }

        function addToCart(id) {
            const product = products.find(p => p.id === id);
            const exist = cart.find(item => item.id === id);

            if (exist) {
                exist.qty += 1;
            } else {
                cart.push({ ...product, qty: 1 });
            }

            updateCartUI();
            
            // Animasi Feedback
            const count = document.getElementById('cart-count');
            count.classList.add('scale-150');
            setTimeout(() => count.classList.remove('scale-150'), 200);
        }

        function removeFromCart(id) {
            cart = cart.filter(item => item.id !== id);
            updateCartUI();
        }

        function updateQty(id, delta) {
            const item = cart.find(i => i.id === id);
            if (item) {
                item.qty += delta;
                if (item.qty < 1) removeFromCart(id);
                else updateCartUI();
            }
        }

        function updateCartUI() {
            const cartItems = document.getElementById('cart-items');
            const cartCount = document.getElementById('cart-count');
            const cartTotal = document.getElementById('cart-total');
            const emptyMsg = document.getElementById('empty-cart-msg');

            if (!cartItems) return;
            cartItems.innerHTML = '';
            let total = 0;
            let count = 0;

            if (cart.length === 0) {
                cartItems.appendChild(emptyMsg);
                cartCount.classList.add('hidden');
            } else {
                cartCount.classList.remove('hidden');
                cart.forEach(item => {
                    total += item.price * item.qty;
                    count += item.qty;

                    const div = document.createElement('div');
                    div.className = 'flex gap-4 items-center bg-gray-50 p-3 rounded-xl';
                    div.innerHTML = `
                        <img src="${item.img}" class="w-16 h-16 object-cover rounded-lg">
                        <div class="flex-1">
                            <h4 class="font-bold text-sm text-gray-800">${item.name}</h4>
                            <p class="text-indigo-600 font-bold text-xs">${formatIDR(item.price)}</p>
                            <div class="flex items-center gap-3 mt-2">
                                <button onclick="updateQty(${item.id}, -1)" class="w-6 h-6 border rounded flex items-center justify-center hover:bg-white">-</button>
                                <span class="text-xs font-bold">${item.qty}</span>
                                <button onclick="updateQty(${item.id}, 1)" class="w-6 h-6 border rounded flex items-center justify-center hover:bg-white">+</button>
                            </div>
                        </div>
                        <button onclick="removeFromCart(${item.id})" class="text-gray-400 hover:text-red-500">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                    `;
                    cartItems.appendChild(div);
                });
            }

            cartCount.innerText = count;
            cartTotal.innerText = formatIDR(total);
            refreshIcons();
        }

        function formatIDR(num) {
            return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(num);
        }

        function checkout() {
            if (cart.length === 0) return alert('Keranjang masih kosong!');

            let message = "Halo LuxeShop, saya ingin memesan:\n\n";
            cart.forEach(item => {
                message += `- ${item.name} (${item.qty}x) = ${formatIDR(item.price * item.qty)}\n`;
            });
            message += `\n*Total: ${document.getElementById('cart-total').innerText}*`;
            
            const waUrl = `https://wa.me/6281234567890?text=${encodeURIComponent(message)}`;
            window.open(waUrl, '_blank');
        }

        // Render Awal setelah DOM siap
        document.addEventListener('DOMContentLoaded', () => {
            // Tunggu sebentar untuk memastikan pustaka eksternal dimuat
            const checkLucide = setInterval(() => {
                if (window.lucide) {
                    clearInterval(checkLucide);
                    renderProducts();
                }
            }, 100);
        });
    </script>
</body>
</html>
